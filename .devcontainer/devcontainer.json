{
    "name": "Claude Code Sandbox",
    "build": { "dockerfile": "Dockerfile" },
    "remoteUser": "yuriy",
    "updateRemoteUserUID": true,
    "containerEnv": {
        "TZ": "America/Los_Angeles"
    },
    "mounts": [
        "source=${localEnv:HOME}/.claude,target=/home/yuriy/.claude,type=bind,Z",
        "source=${localEnv:HOME}/.claude.json,target=/home/yuriy/.claude.json,type=bind,Z",
        "source=${localEnv:HOME}/.local/bin/claude,target=/usr/local/bin/claude,type=bind,Z",
    ]
}

